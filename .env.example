# Environment variables for the gamification platform.
# Copy this file to .env.local and fill in real values (.env.local is gitignored).

# ── Supabase (database) — Supabase dashboard → Project Settings → API ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role key: server-side only, full access — keep secret
SUPABASE_SERVICE_ROLE_KEY=

# ── Vercel (deployment automation) — Vercel → Account Settings → Tokens ──
# Used by CLI/tooling only; not read by the app at runtime.
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_ORG_ID=

# ── bwanabet SSO (token verification) ──
# JWT signing key for the bwanabet `token` cookie (HS256 secret OR RS256 PEM public key).
# REQUIRED in production: without it, tokens can't be verified and /api/session
# + /api/state fail closed (401 token_unverified). Get it from the bwanabet dev team.
BWANABET_JWT_SECRET=
BWANABET_JWT_PUBLIC_KEY=
ALLOWED_PARENT_ORIGINS=https://bwanabet.com,https://www.bwanabet.com
# Escape hatch — trust UNVERIFIED (forgeable) tokens. Dev/testing ONLY. Never set in prod.
SSO_ALLOW_UNVERIFIED=false
